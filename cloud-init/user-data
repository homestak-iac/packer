#cloud-config
# SSH keys for packer build - add your build host's key here
# TODO: Make this dynamic (packer#2 enhancement)
users:
  - name: root
    lock_passwd: false
    ssh_authorized_keys:
      # father (pve1)
      - ssh-rsa  root@pve1
      # mother (pve)
      - ssh-rsa  root@pve

ssh_pwauth: false
disable_root: false
